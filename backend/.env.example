# ── Argonut API — Variables de entorno ────────────────────────────────────────
# Copiar a .env y completar con valores reales antes de correr el servidor.
# Railway inyecta DATABASE_URL automáticamente al provisionar PostgreSQL.

# ── App
APP_NAME="Argonut API"
DEBUG=False
FRONTEND_URL="https://argonut.ar"

# ── Base de datos
# Railway la inyecta automáticamente. Para local, usar tu PostgreSQL:
DATABASE_URL="postgresql://user:password@localhost:5432/argonut"

# ── JWT (generar con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY="cambia-esto-en-produccion-por-una-clave-de-64-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email — opción A: SMTP (Gmail App Password)
EMAIL_BACKEND="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="tu-cuenta@gmail.com"
SMTP_PASSWORD="xxxx-xxxx-xxxx-xxxx"   # App Password de Google
SMTP_FROM="alertas@argonut.ar"
EMAIL_FROM="alertas@argonut.ar"
EMAIL_FROM_NAME="Argonut — Vigilancia de Marcas"

# ── Email — opción B: SendGrid (prioridad sobre SMTP si se define)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="alertas@argonut.ar"

# ── WhatsApp / Twilio (opcional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ── Motor INPI
UMBRAL_SIMILITUD=75
INPI_URL="https://portaltramites.inpi.gob.ar/marcas/busqueda"

# ── Scheduler (APScheduler)
SCHEDULER_TIMEZONE="America/Argentina/Cordoba"
SCHEDULER_CRON_DAY_OF_WEEK="mon"
SCHEDULER_CRON_HOUR=8
SCHEDULER_CRON_MINUTE=0
