# ── Argonut API — Variables de entorno ────────────────────────────────────────
# 1. Copiá este archivo:  cp .env.example .env
# 2. Completá los valores marcados con  ← REQUERIDO
# 3. Railway inyecta DATABASE_URL automáticamente; no la pongas a mano ahí.
# NUNCA commitees el .env — está en .gitignore.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Argonut API"
DEBUG=False
# URL de tu frontend (Railway domain o dominio propio).  ← REQUERIDO en prod
FRONTEND_URL="https://argonut.up.railway.app"

# ── Base de datos ─────────────────────────────────────────────────────────────
# Railway la inyecta automáticamente al provisionar PostgreSQL.
# Para desarrollo local:
DATABASE_URL="postgresql://argonut:password@localhost:5432/argonut"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generá una clave segura con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="cambia-esto-por-una-clave-de-64-chars-generada-con-secrets"  # ← REQUERIDO
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email — Opción A: SMTP (Gmail App Password) ───────────────────────────────
# Activá "Contraseñas de aplicación" en tu cuenta Google y pegá la clave acá.
EMAIL_BACKEND="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""                             # tu-cuenta@gmail.com  ← REQUERIDO para alertas
SMTP_PASSWORD=""                         # xxxx-xxxx-xxxx-xxxx  ← App Password Google
SMTP_FROM="alertas@argonut.ar"
EMAIL_FROM="alertas@argonut.ar"
EMAIL_FROM_NAME="Argonut — Vigilancia de Marcas"

# ── Email — Opción B: SendGrid (prioridad si se define API key) ───────────────
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="alertas@argonut.ar"

# ── WhatsApp / Twilio (opcional) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ── Motor INPI ────────────────────────────────────────────────────────────────
UMBRAL_SIMILITUD=75
# Las URLs INPI tienen defaults correctos en config.py — sólo sobreescribí si cambian.
INPI_SESION_URL="https://portaltramites.inpi.gob.ar/marcasconsultas/busqueda/?Cod_Funcion=NQA0ADE"
INPI_API_URL="https://portaltramites.inpi.gob.ar/MarcasConsultas/GrillaMarcasAvanzada"

# ── Scheduler (APScheduler) ───────────────────────────────────────────────────
# Vigilancia automática: por defecto lunes 08:00 hora Córdoba.
SCHEDULER_TIMEZONE="America/Argentina/Cordoba"
SCHEDULER_CRON_DAY_OF_WEEK="mon"
SCHEDULER_CRON_HOUR=8
SCHEDULER_CRON_MINUTE=0
